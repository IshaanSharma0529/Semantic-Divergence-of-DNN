/**
 * Code Review Graph — Semantic-Divergence-of-DNN
 * ================================================
 * Render with:
 *   - VS Code: install "Graphviz Preview" extension, open this file, press Ctrl+Shift+V
 *   - Online:  paste at  https://dreampuf.github.io/GraphvizOnline
 *   - CLI:     dot -Tpng code_review_graph.dot -o code_review_graph.png
 *
 * Arrows:  solid blue  = Python import dependency
 *          dashed grey = data / file dependency
 *
 * Generated by:  python scripts/code_review_graph.py --text
 */

digraph CodeReviewGraph {

    // ── Global graph style ──
    graph [
        rankdir     = TB,
        splines     = ortho,
        nodesep     = 0.5,
        ranksep     = 0.65,
        fontname    = "Helvetica",
        label       = "Code Review Graph — Semantic-Divergence-of-DNN\nCNN → ViT → VLM adversarial robustness pipeline",
        labelloc    = t,
        fontsize    = 16,
        bgcolor     = "#F8F9FA",
        pad         = 0.5,
    ]
    node [fontname="Helvetica", fontsize=9, style="filled,rounded", shape=box, margin="0.15,0.10"]
    edge [fontname="Helvetica", fontsize=8]

    // ─────────────────────────────────────────────────────────────
    // RAW DATASETS  (ellipses)
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_data {
        label     = "Raw Datasets"
        style     = filled
        fillcolor = "#F0F3F4"
        fontsize  = 10
        color     = "#BDC3C7"

        caltech_zip [
            label     = "caltech-101.zip\n(132 MB)",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
        archive_zip [
            label     = "archive.zip\n(ImageNet-100, 17 GB)",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // DATA SETUP
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_setup {
        label     = "Data Setup Scripts"
        style     = filled
        fillcolor = "#FEF9E7"
        fontsize  = 10
        color     = "#F5CBA7"

        setup_caltech [
            label     = "scripts/setup_caltech101.py\nExtracts zip → nested tar.gz",
            fillcolor = "#E67E22",
            fontcolor = white
        ]
        setup_imagenet [
            label     = "scripts/setup_imagenet100.py\nKaggle 4-shard format → train/val/test",
            fillcolor = "#E67E22",
            fontcolor = white
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // DATA ARTIFACTS  (ellipses)
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_artifacts {
        label     = "Data Artifacts"
        style     = filled
        fillcolor = "#F9F0FF"
        fontsize  = 10
        color     = "#D2B4DE"

        caltech_data [
            label     = "caltech101_data/\n101_ObjectCategories/",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
        imagenet_data [
            label     = "ImageNet100_Training/data/\n{train, val, test}/{synset}/",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
        checkpoints [
            label     = "Model Training/checkpoints/\n*.h5  (VGG19, ResNet50, DenseNet121)",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
        frozen_split [
            label     = "frozen_split_indices.json\nseed=42  |  869 test samples",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
        swin_ckpt [
            label     = "Swin_Training/checkpoints/\nswin_base_imagenet100_best.pt",
            shape     = ellipse,
            fillcolor = "#95A5A6",
            fontcolor = white
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // TRAINING
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_training {
        label     = "Training"
        style     = filled
        fillcolor = "#E9F7EF"
        fontsize  = 10
        color     = "#A9DFBF"

        model_training [
            label     = "Model Training/Model_Training.ipynb\nVGG19 · ResNet50 · DenseNet121",
            fillcolor = "#8E44AD",
            fontcolor = white
        ]
        train_swin [
            label     = "VIT/train_swin.py\nSwin-Base · 100-class head · PyTorch AMP",
            fillcolor = "#27AE60",
            fontcolor = white
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // CORE LIBRARIES
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_core {
        label     = "Core Libraries  (shared utility layer)"
        style     = filled
        fillcolor = "#EAF4FB"
        fontsize  = 10
        color     = "#AED6F1"

        shared_utils [
            label     = "src/shared_utils.py\nload_test_split() · fgsm_attack() · pgd_attack()\ndeepfool_attack() · evaluate_under_attack()\n──────────────────────────────\nTF 2.15.1  |  SEED=42  |  BATCH=8",
            fillcolor = "#2980B9",
            fontcolor = white,
            penwidth  = 2.5
        ]
        adv_bank_cls [
            label     = "src/attacks/adversarial_bank.py\nAdversarialBank class\nadd_record() · flush_all() · summary()",
            fillcolor = "#3498DB",
            fontcolor = white
        ]
        swin_utils [
            label     = "VIT/src/swin_utils.py\nImageNet100Dataset · load_swin_model()\nfgsm_attack_swin() · pgd_attack_swin()\n──────────────────────────────\nPyTorch  |  HuggingFace Transformers",
            fillcolor = "#1E8449",
            fontcolor = white,
            penwidth  = 2.0
        ]
        cnn_attacks_nb [
            label     = "Model Training/cnn-attacks.ipynb\n(original attack implementation\n→ extracted into shared_utils.py)",
            fillcolor = "#8E44AD",
            fontcolor = white,
            style     = "filled,rounded,dashed"
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // EXPERIMENTS
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_experiments {
        label     = "Experiments  (Week 1 Tasks)"
        style     = filled
        fillcolor = "#FDEDEC"
        fontsize  = 10
        color     = "#F1948A"

        build_bank [
            label     = "experiments/build_adversarial_bank.py\nTask 2 — save ALL adv examples + metadata\nbuild_fgsm_bank() · build_pgd_bank() · build_deepfool_bank()",
            fillcolor = "#85C1E9",
            fontcolor = "#1A2533"
        ]
        grad_mask [
            label     = "experiments/gradient_masking_test.py\nTask 1 ✓ DONE\ncompute_gradient_norms() · restart_pgd()\nmonotonicity_check() · generate_verdict()",
            fillcolor = "#85C1E9",
            fontcolor = "#1A2533"
        ]
        transfer_mat [
            label     = "experiments/transfer_attack_matrix.py\nTask 3 — 3×3 source→target transfer\nbuild_transfer_matrix_{fgsm,pgd}()\nanalyse_transferability()",
            fillcolor = "#85C1E9",
            fontcolor = "#1A2533"
        ]
        confusion [
            label     = "experiments/confusion_direction_analysis.py\nTask 4 ★ CORE PAPER CONTRIBUTION\nbuild_adversarial_confusion()\ncompute_semantic_structure_score()\nextract_top_confused_pairs()",
            fillcolor = "#C0392B",
            fontcolor = white,
            penwidth  = 3.0,
            shape     = "box"
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // STATISTICAL VALIDATION
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_validation {
        label     = "Statistical Validation  (Task 5)"
        style     = filled
        fillcolor = "#E8F8F5"
        fontsize  = 10
        color     = "#76D7C4"

        multi_seed [
            label     = "scripts/multi_seed_runner.py\nTask 5a — seeds {42, 123, 456}\nevaluate_{fgsm,pgd}_per_sample()",
            fillcolor = "#16A085",
            fontcolor = white
        ]
        aggregate [
            label     = "scripts/aggregate_results.py\nTask 5b — bootstrap CI · Wilcoxon test\nbootstrap_ci()  |  LaTeX table export",
            fillcolor = "#16A085",
            fontcolor = white
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // PAPER OUTPUTS
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_outputs {
        label     = "Paper Outputs"
        style     = filled
        fillcolor = "#F2F3F4"
        fontsize  = 10
        color     = "#BDC3C7"

        paper_results [
            label     = "results/\ntables  ·  figures  ·  JSON\n→ IEEE TIFS submission",
            shape     = ellipse,
            fillcolor = "#2C3E50",
            fontcolor = white
        ]
    }

    // ─────────────────────────────────────────────────────────────
    // EDGES — data flow  (dashed grey)
    // ─────────────────────────────────────────────────────────────
    edge [style=dashed, color="#7F8C8D", arrowhead=open, arrowsize=0.8]

    caltech_zip    -> setup_caltech    [label="input"]
    archive_zip    -> setup_imagenet   [label="input"]
    setup_caltech  -> caltech_data     [label="extracts to"]
    setup_imagenet -> imagenet_data    [label="extracts to"]

    caltech_data   -> model_training   [label="trains on"]
    model_training -> checkpoints      [label="saves"]
    model_training -> frozen_split     [label="saves"]

    imagenet_data  -> train_swin       [label="trains on"]
    train_swin     -> swin_ckpt        [label="saves"]

    checkpoints    -> shared_utils     [label="loads"]
    frozen_split   -> shared_utils     [label="loads"]
    caltech_data   -> shared_utils     [label="reads"]
    imagenet_data  -> swin_utils       [label="reads"]

    build_bank     -> transfer_mat     [label="bank →\n(pre-gen adv)"]
    build_bank     -> confusion        [label="bank →\n(pre-gen adv)"]

    multi_seed     -> aggregate        [label="per-sample\nresults →"]

    grad_mask      -> paper_results    [label="results"]
    transfer_mat   -> paper_results    [label="results"]
    confusion      -> paper_results    [label="★ main result"]
    aggregate      -> paper_results    [label="CI + tests"]
    swin_ckpt      -> paper_results    [label="ViT results"]

    cnn_attacks_nb -> shared_utils     [label="extracted\ninto →", style="dashed", color="#9B59B6"]

    // ─────────────────────────────────────────────────────────────
    // EDGES — import dependency  (solid blue)
    // ─────────────────────────────────────────────────────────────
    edge [style=solid, color="#2980B9", arrowhead=normal, arrowsize=0.9]

    swin_utils  -> train_swin

    shared_utils -> build_bank
    shared_utils -> grad_mask
    shared_utils -> transfer_mat
    shared_utils -> confusion
    shared_utils -> multi_seed
    shared_utils -> aggregate     [label="constants"]
    shared_utils -> adv_bank_cls  [label="(internal)"]

    adv_bank_cls -> build_bank    [label="AdversarialBank"]

}
